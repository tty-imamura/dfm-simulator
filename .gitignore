.claude/
.DS_Store
*.swp
.vscode/
.idea/
.env*
# LaTeX ビルド生成物(Notes.bib は revtex4-2 の自動生成)
paper/*.aux
paper/*.log
paper/*.out
paper/*.pdf
paper/*Notes.bib
